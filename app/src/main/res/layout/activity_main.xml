<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top bar: source selector + mode toggles + refresh + settings -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Spinner
            android:id="@+id/spinnerSource"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:entries="@array/source_array" />

        <!-- Search Mode Toggle: Torrents/Videos -->
        <RadioGroup
            android:id="@+id/radioGroupMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp">

            <RadioButton
                android:id="@+id/radioTorrents"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="🧲"
                android:textSize="16sp"
                android:checked="true"
                android:button="@null"
                android:background="@drawable/radio_selector"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center" />

            <RadioButton
                android:id="@+id/radioVideos"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="🎬"
                android:textSize="16sp"
                android:button="@null"
                android:background="@drawable/radio_selector"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:gravity="center" />

        </RadioGroup>

        <ImageButton
            android:id="@+id/buttonRefresh"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh Connection"
            android:src="@android:drawable/ic_menu_rotate" />

        <ImageButton
            android:id="@+id/buttonSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Settings"
            android:src="@android:drawable/ic_menu_preferences" />
    </LinearLayout>

    <!-- Search + buttons -->
    <EditText
        android:id="@+id/editTextQuery"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:hint="Search..."
        android:imeOptions="actionSearch"
        android:inputType="text"
        app:layout_constraintEnd_toStartOf="@id/toggleDescriptiveSearch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <CheckBox
        android:id="@+id/toggleDescriptiveSearch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Smart"
        android:textSize="11sp"
        app:layout_constraintEnd_toStartOf="@id/toggleDownloadableOnly"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <CheckBox
        android:id="@+id/toggleDownloadableOnly"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp"
        android:text="DL"
        android:textSize="11sp"
        android:checked="false"
        app:layout_constraintEnd_toStartOf="@id/buttonSearch"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <Button
        android:id="@+id/buttonSearch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="16dp"
        android:text="Search"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar" />

    <TextView
        android:id="@+id/textStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:text="Checking connection..."
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonSearch" />

    <!-- Torrent results recycler -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewResults"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textStatus" />

    <!-- Video results recycler (hidden by default) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewVideoResults"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textStatus" />

</androidx.constraintlayout.widget.ConstraintLayout>