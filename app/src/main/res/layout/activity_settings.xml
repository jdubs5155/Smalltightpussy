<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Jackett/Prowlarr Settings -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jackett Configuration"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configure your Jackett server connection. Find your API key in Jackett web interface (top-right corner)."
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jackett URL (with port)"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Examples:\n• Same network: http://192.168.1.175:9117\n• Localhost (PC): http://localhost:9117\n• Custom port: http://192.168.1.100:8080"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editJackettUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://192.168.1.175:9117"
            android:inputType="textUri"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Jackett API Key"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Copy from: Jackett Dashboard → Top right corner → API Key button"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editJackettApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g., sfbizvj42r5h41a2aojb2t29zouqgd3s"
            android:inputType="text"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prowlarr Configuration"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configure your Prowlarr server connection. API key is in Settings → General → Security."
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prowlarr URL (with port)"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Examples:\n• Default port: http://192.168.1.175:9696\n• Localhost (PC): http://localhost:9696\n• Custom port: http://192.168.1.100:7878"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editProwlarrUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://192.168.1.175:9696"
            android:inputType="textUri"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Prowlarr API Key"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Copy from: Prowlarr → Settings → General → Security → API Key"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/editProwlarrApiKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g., 11e5676f4c3444479cea3671a6c0c55b"
            android:inputType="text"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="qBittorrent Settings"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/checkEnableQb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/qb_enabled_label"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/qb_base_url_label"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/editQbBaseUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://192.168.1.100:8080"
            android:inputType="textUri"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/qb_username_label"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/editQbUsername"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="admin"
            android:inputType="text"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/qb_password_label"
            android:textSize="14sp"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/editQbPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="password"
            android:inputType="textPassword"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/buttonSaveSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/save_button" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📚 Provider Management"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manage all torrent providers from one place"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/buttonManageIndexers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔧 All Providers (Built-in + Imported)"
            android:backgroundTint="#9B59B6"
            android:textColor="@android:color/white"
            android:padding="16dp" />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="View and toggle all providers including 60+ built-in providers and imported indexers"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/buttonImportIndexers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📥 Import from Jackett/Prowlarr"
            android:backgroundTint="#3498DB"
            android:textColor="@android:color/white"
            android:padding="16dp" />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Import individual indexers with their unique Torznab URLs"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/buttonAddCustomURLs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚀 Smart Add (Just Paste URL!)"
            android:backgroundTint="#2ECC71"
            android:textColor="@android:color/white"
            android:padding="16dp" />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Automatically detect and add any torrent site by URL - no manual configuration!"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/buttonManageBuiltInProviders"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="📊 View Built-in Provider Stats"
            android:backgroundTint="#95A5A6"
            android:visibility="gone" />

        <!-- Tracker Management Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📡 Tracker Management"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enhance magnet links with 200+ fast trackers for better download speeds"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/buttonManageTrackers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ Manage Super Fast Trackers (200+)"
            android:backgroundTint="#E67E22"
            android:textColor="@android:color/white"
            android:padding="16dp" />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Automatically adds reliable UDP/HTTP trackers to magnet links for improved peer discovery"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <!-- Video Sites Management Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎬 Video Sites"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Search clearnet video sites like YouTube, Vimeo, Dailymotion, Rumble, and more"
            android:textSize="12sp"
            android:textColor="#666666"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/buttonManageVideoSites"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎥 Manage Video Sites (10+)"
            android:backgroundTint="#E74C3C"
            android:textColor="@android:color/white"
            android:padding="16dp" />
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add and configure video sites for searching. Use 'Videos' mode in main screen to search."
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

    </LinearLayout>

</ScrollView>
