<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎬 Clearnet Video Sites"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/textSiteCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 video sites configured"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/buttonAddSite"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="+ Add URL"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/buttonAddPreset"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Presets"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/buttonTestAll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Test All"
            android:layout_marginStart="4dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/textEmptyMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No video sites added yet.\n\nTap 'Add URL' to paste a video site URL, or use 'Presets' to add popular sites like YouTube, Dailymotion, Vimeo, etc."
        android:textSize="14sp"
        android:textColor="#888888"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewSites"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
