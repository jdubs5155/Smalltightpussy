<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Torrent Tracker Management"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enhance magnet links with fast, reliable trackers to improve download speeds and peer discovery."
        android:textSize="12sp"
        android:textColor="#999999"
        android:layout_marginBottom="16dp" />

    <!-- Enable/Disable Switch -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#222222"
        android:padding="12dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Enhance magnet links"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchEnableTrackers"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- Tracker Info -->
    <TextView
        android:id="@+id/textTrackerInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="0 trackers active"
        android:textSize="14sp"
        android:textColor="#00AA00"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/textTrackerStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="UDP: 0 | HTTP: 0 | HTTPS: 0"
        android:textSize="12sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/buttonUseTop50"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Top 50"
            android:textSize="12sp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/buttonUseAll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Use All"
            android:textSize="12sp"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/buttonAddTracker"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Add"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- NEW: 200+ Tracker Manager Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📊 200+ Tracker Database"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/buttonCopyAllTrackers"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Copy All 200+"
            android:textSize="11sp"
            android:layout_marginEnd="4dp"
            android:backgroundTint="#00AA00" />

        <Button
            android:id="@+id/buttonViewDatabase"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="👁️ View Database"
            android:textSize="11sp"
            android:layout_marginEnd="4dp" />
    </LinearLayout>

    <Button
        android:id="@+id/buttonScanTrackers"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔍 Scan Trackers for Search APIs (Tool-X)"
        android:textSize="12sp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#FF6600" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Scan will auto-detect search capabilities and add compatible trackers to built-in providers for 'Everything' search."
        android:textSize="10sp"
        android:textColor="#999999"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/buttonResetDefaults"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset to Defaults"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <!-- Tracker List -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Active Trackers (Long press to remove):"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerTrackers"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#111111" />

</LinearLayout>
